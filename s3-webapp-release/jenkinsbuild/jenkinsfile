pipeline {
    agent {
        label 'Agent_1'
    }

    environment {
        S3_BUCKET = 'aws-jenkins-webapp'    
        AWS_REGION = 'ap-south-1'
    }

    stages{
        stage("AppCode Checkout"){
            steps{
                git branch:'master', url: 'https://github.com/AshwiniKY/Jenkins-Learning.git'
            }
        }
        stage("Deploy Code to S3"){
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding', 
                    credentialsId: 'aws_creds'
                ]]) {
                    sh '''
                    aws s3 sync $WORKSPACE/src/ s3://$S3_BUCKET --delete
                    '''
                }
            }
        }
    }    
    post {
        success {
            echo "Deployment of s3 bucket success"
        }
        failure { 
            echo "your job is failed"
        }
   }
}   
