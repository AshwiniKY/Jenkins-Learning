pipeline {
    agent {
        label 'Jenkins_Agent_1'
    }

    stages{
        stage("AppCode Checkout"){
            steps{
                git branch:'master', url: 'https://github.com/AshwiniKY/Jenkins-Learning.git'
            }
        }

        stage("Prepareserver"){
            steps{
                sh '''
                sudo yum install httpd -y 
                sudo systemctl start httpd 
                sudo systemctl enable httpd '''
            }
        }

        stage("CopyContent"){
            steps{
                sh 'sudo cp -rvf $WORKSPACE/webapp/src/  /var/www/html'
            }
        }
    }
}